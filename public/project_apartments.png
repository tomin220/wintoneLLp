<svg xmlns="http://www.w3.org/2000/svg" width="800" height="600" viewBox="0 0 800 600">
  <defs>
    <linearGradient id="g" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#111111"/>
      <stop offset="100%" style="stop-color:#0a0a0a"/>
    </linearGradient>
  </defs>
  <rect width="800" height="600" fill="url(#g)"/>
  <!-- Apartment tower -->
  <rect x="200" y="100" width="400" height="400" fill="#1a1a1a"/>
  <!-- Window grid -->
  <rect x="230" y="130" width="50" height="40" fill="#c9a84c" opacity="0.25"/>
  <rect x="300" y="130" width="50" height="40" fill="#c9a84c" opacity="0.2"/>
  <rect x="370" y="130" width="50" height="40" fill="#c9a84c" opacity="0.3"/>
  <rect x="440" y="130" width="50" height="40" fill="#c9a84c" opacity="0.15"/>
  <rect x="510" y="130" width="50" height="40" fill="#c9a84c" opacity="0.25"/>
  <rect x="230" y="190" width="50" height="40" fill="#c9a84c" opacity="0.2"/>
  <rect x="300" y="190" width="50" height="40" fill="#c9a84c" opacity="0.3"/>
  <rect x="370" y="190" width="50" height="40" fill="#c9a84c" opacity="0.2"/>
  <rect x="440" y="190" width="50" height="40" fill="#c9a84c" opacity="0.25"/>
  <rect x="510" y="190" width="50" height="40" fill="#c9a84c" opacity="0.2"/>
  <rect x="230" y="250" width="50" height="40" fill="#c9a84c" opacity="0.3"/>
  <rect x="300" y="250" width="50" height="40" fill="#c9a84c" opacity="0.15"/>
  <rect x="370" y="250" width="50" height="40" fill="#c9a84c" opacity="0.25"/>
  <rect x="440" y="250" width="50" height="40" fill="#c9a84c" opacity="0.2"/>
  <rect x="510" y="250" width="50" height="40" fill="#c9a84c" opacity="0.3"/>
  <!-- Entrance -->
  <rect x="340" y="420" width="120" height="80" fill="#0a0a0a"/>
  <!-- Gold accent -->
  <line x1="200" y1="100" x2="600" y2="100" stroke="#c9a84c" stroke-width="2" opacity="0.6"/>
  <text x="400" y="540" font-family="Georgia, serif" font-size="28" fill="#c9a84c" text-anchor="middle">Luxury Apartments</text>
  <text x="400" y="570" font-family="Arial, sans-serif" font-size="12" fill="#9ca3af" text-anchor="middle" letter-spacing="3">WINSTONE PROJECTS</text>
</svg>
