<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="800" viewBox="0 0 1200 800">
  <defs>
    <linearGradient id="g" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0a0a0a"/>
      <stop offset="100%" style="stop-color:#111111"/>
    </linearGradient>
    <radialGradient id="glow" cx="50%" cy="40%" r="50%">
      <stop offset="0%" style="stop-color:#c9a84c;stop-opacity:0.1"/>
      <stop offset="100%" style="stop-color:#0a0a0a;stop-opacity:0"/>
    </radialGradient>
  </defs>
  <rect width="1200" height="800" fill="url(#g)"/>
  <rect width="1200" height="800" fill="url(#glow)"/>
  <!-- Person silhouette -->
  <ellipse cx="600" cy="260" rx="80" ry="90" fill="#1a1a1a"/>
  <rect x="480" y="340" width="240" height="300" fill="#1a1a1a"/>
  <!-- Suit detail -->
  <polygon points="560,340 600,380 640,340 620,340 600,360 580,340" fill="#111"/>
  <!-- Gold tie -->
  <polygon points="595,360 605,360 610,440 590,440" fill="#c9a84c" opacity="0.6"/>
  <!-- Background architecture -->
  <rect x="0" y="500" width="400" height="300" fill="#111" opacity="0.5"/>
  <rect x="800" y="450" width="400" height="350" fill="#111" opacity="0.5"/>
  <!-- Gold accent line -->
  <line x1="0" y1="640" x2="1200" y2="640" stroke="#c9a84c" stroke-width="1" opacity="0.3"/>
  <text x="600" y="700" font-family="Georgia, serif" font-size="32" fill="#c9a84c" text-anchor="middle">Nayaz — Founder</text>
  <text x="600" y="740" font-family="Arial, sans-serif" font-size="14" fill="#9ca3af" text-anchor="middle" letter-spacing="4">WINSTONE PROJECTS</text>
</svg>
