<svg xmlns="http://www.w3.org/2000/svg" width="800" height="600" viewBox="0 0 800 600">
  <defs>
    <linearGradient id="sky" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#0a0a0a"/>
      <stop offset="60%" style="stop-color:#111111"/>
      <stop offset="100%" style="stop-color:#1a1a1a"/>
    </linearGradient>
  </defs>
  <rect width="800" height="600" fill="url(#sky)"/>
  <!-- Ground -->
  <rect x="0" y="420" width="800" height="180" fill="#111"/>
  <!-- Farmhouse -->
  <rect x="150" y="280" width="220" height="140" fill="#1a1a1a"/>
  <polygon points="150,280 260,200 370,280" fill="#222"/>
  <!-- Barn -->
  <rect x="430" y="300" width="180" height="120" fill="#1a1a1a"/>
  <polygon points="430,300 520,240 610,300" fill="#222"/>
  <!-- Windows -->
  <rect x="180" y="310" width="50" height="40" fill="#c9a84c" opacity="0.25"/>
  <rect x="280" y="310" width="50" height="40" fill="#c9a84c" opacity="0.2"/>
  <rect x="460" y="330" width="40" height="35" fill="#c9a84c" opacity="0.2"/>
  <rect x="540" y="330" width="40" height="35" fill="#c9a84c" opacity="0.2"/>
  <!-- Door -->
  <rect x="235" y="360" width="50" height="60" fill="#0a0a0a"/>
  <!-- Trees -->
  <rect x="80" y="350" width="8" height="70" fill="#333"/>
  <ellipse cx="84" cy="340" rx="25" ry="30" fill="#1a1a1a"/>
  <rect x="660" y="360" width="8" height="60" fill="#333"/>
  <ellipse cx="664" cy="350" rx="22" ry="25" fill="#1a1a1a"/>
  <!-- Gold horizon line -->
  <line x1="0" y1="420" x2="800" y2="420" stroke="#c9a84c" stroke-width="1" opacity="0.4"/>
  <text x="400" y="500" font-family="Georgia, serif" font-size="28" fill="#c9a84c" text-anchor="middle">Farm Estates</text>
  <text x="400" y="530" font-family="Arial, sans-serif" font-size="12" fill="#9ca3af" text-anchor="middle" letter-spacing="3">WINSTONE PROJECTS</text>
</svg>
