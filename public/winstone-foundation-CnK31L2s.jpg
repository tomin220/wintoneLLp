<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="800" viewBox="0 0 1200 800">
  <defs>
    <linearGradient id="g" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0a0a0a"/>
      <stop offset="100%" style="stop-color:#1a1a1a"/>
    </linearGradient>
  </defs>
  <rect width="1200" height="800" fill="url(#g)"/>
  <!-- Foundation building -->
  <rect x="200" y="200" width="800" height="400" fill="#111"/>
  <!-- Columns -->
  <rect x="250" y="200" width="40" height="400" fill="#1a1a1a"/>
  <rect x="380" y="200" width="40" height="400" fill="#1a1a1a"/>
  <rect x="510" y="200" width="40" height="400" fill="#1a1a1a"/>
  <rect x="640" y="200" width="40" height="400" fill="#1a1a1a"/>
  <rect x="770" y="200" width="40" height="400" fill="#1a1a1a"/>
  <rect x="900" y="200" width="40" height="400" fill="#1a1a1a"/>
  <!-- Pediment -->
  <polygon points="200,200 600,80 1000,200" fill="#1a1a1a"/>
  <!-- Steps -->
  <rect x="180" y="600" width="840" height="20" fill="#1a1a1a"/>
  <rect x="160" y="620" width="880" height="20" fill="#222"/>
  <rect x="140" y="640" width="920" height="20" fill="#1a1a1a"/>
  <!-- Gold accents -->
  <line x1="200" y1="200" x2="1000" y2="200" stroke="#c9a84c" stroke-width="2" opacity="0.5"/>
  <text x="600" y="150" font-family="Georgia, serif" font-size="32" fill="#c9a84c" text-anchor="middle">Winstone Foundation</text>
  <text x="600" y="700" font-family="Arial, sans-serif" font-size="14" fill="#9ca3af" text-anchor="middle" letter-spacing="4">COMMUNITY &amp; LEGACY</text>
</svg>
