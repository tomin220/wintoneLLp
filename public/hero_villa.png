<svg xmlns="http://www.w3.org/2000/svg" width="1920" height="1080" viewBox="0 0 1920 1080">
  <rect width="1920" height="1080" fill="#0a0a0a"/>
  <rect x="0" y="0" width="1920" height="1080" fill="url(#grad1)"/>
  <defs>
    <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0a0a0a;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#1a1a1a;stop-opacity:1" />
    </linearGradient>
  </defs>
  <!-- Villa silhouette -->
  <rect x="560" y="500" width="800" height="300" fill="#111"/>
  <polygon points="560,500 960,300 1360,500" fill="#1a1a1a"/>
  <rect x="700" y="580" width="120" height="220" fill="#0a0a0a"/>
  <rect x="1100" y="580" width="120" height="220" fill="#0a0a0a"/>
  <rect x="860" y="600" width="200" height="200" fill="#0a0a0a"/>
  <!-- Windows with gold glow -->
  <rect x="720" y="610" width="80" height="60" fill="#c9a84c" opacity="0.3"/>
  <rect x="1120" y="610" width="80" height="60" fill="#c9a84c" opacity="0.3"/>
  <rect x="880" y="630" width="160" height="120" fill="#c9a84c" opacity="0.2"/>
  <!-- Gold accent line -->
  <line x1="400" y1="800" x2="1520" y2="800" stroke="#c9a84c" stroke-width="1" opacity="0.4"/>
  <!-- Label -->
  <text x="960" y="200" font-family="Georgia, serif" font-size="48" fill="#c9a84c" text-anchor="middle" opacity="0.9">WINSTONE PROJECTS</text>
  <text x="960" y="260" font-family="Arial, sans-serif" font-size="20" fill="#9ca3af" text-anchor="middle" letter-spacing="6">LUXURY REAL ESTATE</text>
  <text x="960" y="920" font-family="Arial, sans-serif" font-size="16" fill="#c9a84c" text-anchor="middle" opacity="0.6">Hero Villa</text>
</svg>
